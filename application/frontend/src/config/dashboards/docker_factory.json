{
  "id": "docker_factory_default",
  "title": "容器化工厂 实时看板",
  "layout": "grid-2col",
  "cards": [
    { "hook": "machine_util",   "template": "line", "title": "机器利用率",   "yMax": 100, "unit": "%" },
    { "hook": "efficiency",     "template": "line", "title": "系统效率",     "yMax": 100, "unit": "%" },
    { "hook": "agv_activity",   "template": "line", "title": "AGV 活动数" },
    { "hook": "job_progress",   "template": "line", "title": "Job 完成进度" },
    { "hook": "machine_load",   "template": "bar",  "title": "各机器负载",   "mode": "grouped" },
    { "hook": "agv_stats",      "template": "line", "title": "AGV 综合指标", "multiSeries": true },
    { "hook": "exception_summary", "template": "line", "title": "异常累计", "multiSeries": true },
    { "hook": "event_timeline", "template": "line", "title": "事件累计",     "multiSeries": true }
  ]
}
