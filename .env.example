# ============================================
# SkyEngine 环境变量配置示例
# 复制为 .env 后填写实际值: cp .env.example .env
# ============================================

# ---------- SkyEngine 在线仿真服务 ----------
# SkyEngine docker-compose-online.yaml 的绝对路径 (容器内挂载用)
SKYENGINE_COMPOSE_PATH=/path/to/SkyEngine/docker-compose-online.yaml

# SkyEngine 项目根目录 (docker compose 启动服务需要读取宿主机路径)
SKYENGINE_PROJECT_DIR=/path/to/SkyEngine

# ---------- RAG 助手 (vLLM) ----------
# RAG 后端服务地址
RAG_BACKEND_URL=http://127.0.0.1:8000

# RAG 模型名称
RAG_MODEL_NAME=qwen3.6-35b

# RAG API Key (本地推理服务可留空)
RAG_API_KEY=

# ---------- GPU ----------
# 可见 GPU 设备
CUDA_VISIBLE_DEVICES=0
